---
layout: base.njk
---

<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      <span class="post-kind">{{ kind or "note" }}</span>
      <time datetime="{{ date | date('YYYY-MM-DD') }}">{{ date | dateDisplay }}</time>
      {% if updated %}
      <span>updated {{ updated | dateDisplay }}</span>
      {% endif %}
      {% if status %}
      <span class="post-status">{{ status }}</span>
      {% endif %}
      {% if tags %}
      <span class="post-tags">
        {% for tag in tags %}
          {% if tag != "posts" %}
            <a href="/tags/{{ tag }}/" class="tag">{{ tag }}</a>
          {% endif %}
        {% endfor %}
      </span>
      {% endif %}
    </div>
  </header>

  <div class="post-content">
    {{ content | safe }}
  </div>

  <nav class="post-nav">
    <a href="/blog/">← All posts</a>
  </nav>
</article>
