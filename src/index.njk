---
layout: base.njk
title: Home
---

{% set currentThreads = [
  {
    label: "Research",
    title: "Graphons and Extremal Combinatorics",
    description: "Trying to understand, how higher order interactions in large graphs change as you constrain triangle density."
  },
  {
    label: "Learning",
    title: "Differential Topology and Geometry",
    description: "Studying Differential Topology and Geometry for Geomerty and Topology Qualifier."
  }
] %}

{% set entryWays = [
  {
    title: "Research log",
    href: "/blog/",
    meta: "rough / dated / in progress",
    description: "Working notes from the day-to-day process: questions, dead ends, small wins, and things worth remembering."
  },
  {
    title: "Notes",
    href: "/tags/notes/",
    meta: "semi-polished / reusable",
    description: "Expository writeups and reference pages that may keep changing as I understand the material better."
  },
  {
    title: "Experiments",
    href: "/tags/experiments/",
    meta: "interactive / computational",
    description: "Demos, visualizations, code sketches, and mathematical toys that make an idea less static."
  },
  {
    title: "Papers",
    href: "#papers",
    meta: "formal / citable",
    description: "The more official record: preprints, publications, and finished research artifacts."
  }
] %}

<section class="garden-hero">
  <div class="hero-copy">
    <p class="eyebrow">{{ metadata.title }}{% if metadata.institution %} · {{ metadata.institution }}{% endif %}</p>
    <h1>{{ metadata.name }}</h1>
    <p class="hero-lede">
      A public research desk for mathematics, notes, experiments, and the trails I am following as a PhD student.
    </p>
    <p class="profile-bio">{{ metadata.homeDescription }}</p>
    <nav class="profile-links" aria-label="Profile links">
      <a href="/assets/cv/cv.pdf" target="_blank" rel="noopener">CV</a>
      <a href="{{ metadata.github }}" target="_blank" rel="noopener">GitHub</a>
      <a href="mailto:{{ metadata.email }}">Email</a>
    </nav>
  </div>

  <div class="profile-photo-wrap">
    <img
      src="/assets/img/profile.png"
      alt="{{ metadata.name }}"
      class="profile-photo"
      width="320"
      height="400"
      onerror="this.closest('.profile-photo-wrap').remove()"
    />
  </div>
</section>

<section class="thread-board" aria-labelledby="threads-heading">
  <div class="section-kicker">Current threads</div>
  <h2 id="threads-heading">Things I am circling right now</h2>
  <ol class="thread-list">
    {% for thread in currentThreads %}
    <li class="thread-item">
      <span class="thread-label">{{ thread.label }}</span>
      <h3>{{ thread.title }}</h3>
      <p>{{ thread.description }}</p>
    </li>
    {% endfor %}
  </ol>
</section>

<section class="entry-ways" aria-labelledby="entry-heading">
  <div class="section-kicker">Ways in</div>
  <h2 id="entry-heading">The garden, kept organized</h2>
  <div class="entry-grid">
    {% for way in entryWays %}
    <a class="entry-way" href="{{ way.href }}">
      <span class="entry-meta">{{ way.meta }}</span>
      <strong>{{ way.title }}</strong>
      <span>{{ way.description }}</span>
    </a>
    {% endfor %}
  </div>
</section>

<section class="recent-posts">
  <div class="section-kicker">Recent entries</div>
  <h2>Latest from the desk</h2>
  <ul class="post-list">
    {% set recentPosts = collections.posts | reverse | first(4) %}
    {% for post in recentPosts %}
    <li class="post-list-item">
      <div class="post-list-meta">
        <span class="post-kind">{{ post.data.kind or "note" }}</span>
        <time class="post-list-date">{{ post.date | dateDisplay }}</time>
        {% if post.data.status %}
          <span class="post-status">{{ post.data.status }}</span>
        {% endif %}
      </div>
      <a href="{{ post.url }}" class="post-list-title">{{ post.data.title }}</a>
      {% if post.data.summary %}
        <p class="post-list-summary">{{ post.data.summary }}</p>
      {% endif %}
      {% if post.data.tags %}
      <span class="post-tags">
        {% for tag in post.data.tags %}
          {% if tag != "posts" %}
            <a href="/tags/{{ tag }}/" class="tag">{{ tag }}</a>
          {% endif %}
        {% endfor %}
      </span>
      {% endif %}
    </li>
    {% endfor %}
  </ul>
  <a href="/blog/" class="more-link">Open the garden archive</a>
</section>

<hr class="section-divider" />

<!-- PAPERS & PUBLICATIONS -->
<section class="papers" id="papers">
  <div class="section-kicker">Formal work</div>
  <h2>Papers &amp; Publications</h2>

  {% if papers.length == 0 %}
    <p class="muted">Publications will appear here.</p>
  {% else %}
    <ol class="paper-list">
      {% for paper in papers %}
      <li class="paper-item">
        <div class="paper-title">{{ paper.title }}</div>
        <div class="paper-authors">{{ paper.authors }}</div>
        <div class="paper-venue">{{ paper.venue }}</div>
        <details class="paper-abstract">
          <summary>Abstract</summary>
          <div class="abstract-body">{{ paper.abstract | md | safe }}</div>
        </details>
        <div class="paper-links">
          {% if paper.arxiv %}
            <a href="{{ paper.arxiv }}" target="_blank" rel="noopener" class="paper-link">arXiv</a>
          {% endif %}
          {% if paper.pdf %}
            <a href="{{ paper.pdf }}" target="_blank" rel="noopener" class="paper-link">PDF</a>
          {% endif %}
        </div>
      </li>
      {% endfor %}
    </ol>
  {% endif %}
</section>
